{
  "name": "war9a",
  "version": "1.0.0",
  "description": "Virtual queue management platform for Algerian businesses",
  "main": "index.js",
  "workspaces": [
    "apps/*",
    "packages/shared/*"
  ],
  "overrides": {
    "@nestjs/config": {
      "@nestjs/common": "^11.1.2"
    },
    "next": "^16.1.6"
  },
  "scripts": {
    "dev": "docker-compose -f docker-compose.dev.yml up --build",
    "prod": "docker-compose -f docker-compose.prod.yml up --build",
    "prod:build": "docker-compose -f docker-compose.prod.yml build",
    "build:shared": "tsc -p packages/shared/drizzle/tsconfig.json && tsc --build packages/shared/types/tsconfig.json",
    "build:all:watch": "npx nx run-many -t dev --projects=@shared/drizzle,@shared/types,@shared/mobile --parallel",
    "dev:local": "npx nx run-many -t dev --projects=@shared/drizzle,@shared/types,@shared/mobile,backend,frontend --parallel",
    "nx": "nx",
    "nx:graph": "nx graph",
    "nx:build": "nx run-many -t build",
    "nx:dev": "nx run-many -t dev --parallel",
    "nx:lint": "nx run-many -t lint",
    "nx:test": "nx run-many -t test"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "npm@10.9.2",
  "dependencies": {
    "@radix-ui/react-separator": "^1.1.8",
    "minidenticons": "^4.2.1",
    "next": "^16.1.6",
    "nx": "20.0.0",
    "react-leaflet-cluster": "^4.0.0",
    "typescript": "^5.8.3"
  },
  "devDependencies": {
    "@types/node": "^24.0.1",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.1.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "shadcn": "^4.1.0",
    "tw-animate-css": "^1.4.0"
  }
}
