{
  "name": "@shared/drizzle",
  "version": "1.0.0",
  "description": "Shared Drizzle ORM schema, migrations and DB client for War9a",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./schema": "./dist/schema/index.js",
    "./schema/*": "./dist/schema/*.js",
    "./operators": "./dist/operators.js",
    "./*": "./dist/*.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc --watch -p tsconfig.json",
    "drizzle:generate": "drizzle-kit generate",
    "drizzle:migrate": "drizzle-kit migrate",
    "drizzle:studio": "drizzle-kit studio",
    "drizzle:seed": "ts-node --compiler-options '{\"module\":\"CommonJS\"}' seed.ts",
    "drizzle:simulate": "ts-node --compiler-options '{\"module\":\"CommonJS\"}' simulate.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "npm@10.9.2",
  "dependencies": {
    "@types/bcrypt": "^6.0.0",
    "bcrypt": "^6.0.0",
    "dotenv": "^16.5.0",
    "drizzle-kit": "^0.31.8",
    "drizzle-orm": "^0.43.1",
    "pg": "^8.16.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.27",
    "@types/pg": "^8.15.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  }
}
