# =============================================================================
# War9a - Environment Variables Example
# Copy to .env and fill in values
# =============================================================================

# --- Runtime ---
NODE_ENV=development

# --- Database ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/war9a
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme_in_production
POSTGRES_DB=war9a

# --- Redis ---
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# --- Auth (better-auth) ---
# Must be at least 32 characters
BETTER_AUTH_SECRET=changeme_minimum_32_chars_required_here!
BETTER_AUTH_URL=https://api.war9a.localhost/auth
SESSION_COOKIE_SECURE=false
# Options: lax | strict | none (none requires SESSION_COOKIE_SECURE=true)
COOKIE_SAME_SITE=lax
# Leave empty for localhost; set to ".war9a.com" for production cross-subdomain
COOKIE_DOMAIN=
# Options: hybrid | github_only
AUTH_MODE=hybrid

# --- OAuth Providers (optional) ---
GOOGLE_AUTH_ENABLED=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Frontend / CORS ---
FRONTEND_URL=https://war9a.localhost
CORS_ALLOWED_ORIGINS=https://war9a.localhost
TRUSTED_ORIGINS=https://war9a.localhost
NEXT_PUBLIC_BACKEND_URL=https://api.war9a.localhost

# --- MinIO Object Storage ---
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
# Public URL for CDN access (e.g. https://cdn.war9a.com in production)
MINIO_PUBLIC_ENDPOINT=cdn.war9a.localhost

# --- Web Push Notifications (VAPID) ---
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=admin@war9a.app

# --- Email (SMTP) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@war9a.app

# --- Domain (production) ---
DOMAIN=war9a.example.com
COOKIE_DOMAIN=.war9a.example.com

# --- Monitoring (optional) ---
GRAFANA_PASSWORD=admin
